{
  "name": "rollorian-book-archive-backend",
  "version": "0.1.0",
  "private": true,
  "main": "src/server.js",
  "scripts": {
    "setup": "npm install --no-package-lock && node scripts/setup.js",
    "dev": "node --env-file-if-exists=.env --watch src/server.js",
    "start": "node --env-file-if-exists=.env src/server.js",
    "test": "node --env-file-if-exists=.env ./node_modules/prisma/build/index.js db push --skip-generate && node --env-file-if-exists=.env --test",
    "smoke:responsive": "node --env-file-if-exists=.env scripts/responsive-smoke.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "playwright-core": "^1.58.2",
    "prisma": "^6.6.0",
    "supertest": "^7.2.2"
  }
}
